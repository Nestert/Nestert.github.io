{
  "name": "new-roman-site",
  "version": "1.0.0",
  "description": "Minimalist artist portfolio website",
  "scripts": {
    "dev": "sass --watch src/assets/scss:src/assets/css & eleventy --serve",
    "build": "rm -rf _site && sass src/assets/scss/main.scss src/assets/css/main.css && eleventy",
    "lint": "npx eslint \"src/assets/js/**/*.js\"",
    "check": "npm run lint && npm run build",
    "test": "npm run check"
  },
  "keywords": [
    "portfolio",
    "artist",
    "gallery",
    "eleventy"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "@11ty/eleventy-img": "^4.0.2",
    "eslint": "^8.56.0",
    "prettier": "^3.2.5",
    "sass": "^1.70.0"
  }
}
