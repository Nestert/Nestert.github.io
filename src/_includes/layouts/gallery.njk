---
layout: layouts/base.njk
---

{% set page_collection = "projects" %}
{% if "живопись" in title|lower or "paintings" in title|lower %}
  {% set page_collection = "paintings" %}
{% elif "графика" in title|lower or "drawings" in title|lower %}
  {% set page_collection = "drawings" %}
{% endif %}

<div class="gallery">
  <div class="gallery__grid">
    {% for work in collections[page_collection] | sortByOrder %}
      <article class="gallery__item">
        <a href="{{ work.data.image }}" class="gallery__link" data-lightbox="gallery" data-title="{{ work.data.title }}">
          <img src="{{ work.data.thumbnail or work.data.image }}" alt="{{ work.data.title }}" class="gallery__image" loading="lazy">
        </a>
      </article>
    {% endfor %}
  </div>
</div>

{% include "components/lightbox.njk" %}
