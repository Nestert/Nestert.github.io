---
layout: layouts/base.njk
---

<div class="container">
  <section class="category-hero">
    <h1 class="category-hero__title">{{ title }}</h1>
  </section>

  <section class="section section--category-gallery">
    <div class="gallery__grid">
      {% for work in collections[categoryKey] | sortByYearDesc %}
        {% set cardLoading = "lazy" %}
        {% set cardPriority = "" %}
        {% if loop.index <= 4 %}
          {% set cardLoading = "eager" %}
        {% endif %}
        {% if loop.first %}
          {% set cardPriority = "high" %}
        {% endif %}
        <article class="project-card">
          <a href="{{ work.url }}" class="project-card__link">
            {% set previewImage = work.data.thumbnail or work.data.image %}
            {% cardImage previewImage, work.data.title, "project-card__image", cardLoading, cardPriority %}
            <div class="project-card__overlay">
              <h2 class="project-card__title">{{ work.data.title }}</h2>
              {% if work.data.yearLabel or work.data.year %}
                <p class="project-card__year">{{ work.data.yearLabel or work.data.year }}</p>
              {% endif %}
            </div>
          </a>
        </article>
      {% endfor %}
    </div>
  </section>
</div>
