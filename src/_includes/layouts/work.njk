---
layout: layouts/base.njk
---

{% set backHref = "/" %}
{% set backLabel = "Назад" %}
{% if "/paintings/" in page.url %}
  {% set backHref = "/paintings/" %}
  {% set backLabel = "Живопись" %}
{% elif "/drawings/" in page.url %}
  {% set backHref = "/drawings/" %}
  {% set backLabel = "Графика" %}
{% elif "/projects/" in page.url %}
  {% set backHref = "/projects/" %}
  {% set backLabel = "Проекты" %}
{% endif %}
{% set bodyContent = content | striptags | trim %}

<div class="container">
  <article class="work-detail">
    <header class="work-detail__header">
      <h1 class="work-detail__title">{{ title }}</h1>
      {% if year %}
        <p class="work-detail__year">{{ year }}</p>
      {% endif %}
    </header>

    {% if image %}
      <figure class="work-detail__image-wrapper">
        {% detailImage image, title, "work-detail__image" %}
      </figure>
    {% endif %}

    {% if description %}
      <p class="work-detail__description">{{ description }}</p>
    {% endif %}

    {% if bodyContent %}
      <div class="work-detail__content">
        {{ content | safe }}
      </div>
    {% endif %}

    <footer class="work-detail__footer">
      <a href="{{ backHref }}" class="work-detail__back">← {{ backLabel }}</a>
    </footer>
  </article>
</div>
