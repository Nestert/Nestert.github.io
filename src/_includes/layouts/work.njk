---
layout: layouts/base.njk
---

{% set backHref = "/" %}
{% set backLabel = "Назад" %}
{% if "/paintings/" in page.url %}
  {% set backHref = "/paintings/" %}
  {% set backLabel = "Живопись" %}
  {% set categoryItems = collections.paintings %}
{% elif "/drawings/" in page.url %}
  {% set backHref = "/drawings/" %}
  {% set backLabel = "Графика" %}
  {% set categoryItems = collections.drawings %}
{% elif "/projects/" in page.url %}
  {% set backHref = "/projects/" %}
  {% set backLabel = "Проекты" %}
  {% set categoryItems = collections.projects %}
{% endif %}
{% set bodyContent = content | striptags | trim %}
{% set previousWork = categoryItems | getAdjacentWork(page.url, "previous") %}
{% set nextWork = categoryItems | getAdjacentWork(page.url, "next") %}

<div class="container">
  <article class="work-detail">
    <header class="work-detail__header">
      <h1 class="work-detail__title">{{ title }}</h1>
    </header>

    {% if image %}
      {% set imageCount = 1 %}
      {% if gallery %}
        {% set imageCount = (gallery | length) + 1 %}
      {% endif %}
      <section
        class="work-carousel{% if imageCount > 1 %} work-carousel--multiple{% endif %}"
        data-work-carousel
        aria-label="Изображения работы «{{ title }}»"
        aria-roledescription="карусель"
      >
        <div class="work-carousel__viewport" data-carousel-viewport>
          <div class="work-carousel__track" data-carousel-track>
            <figure
              class="work-detail__image-wrapper work-carousel__slide"
              data-carousel-slide
              role="group"
              aria-roledescription="слайд"
              aria-label="1 из {{ imageCount }}"
              aria-hidden="false"
            >
              {% detailImage image, title, "work-detail__image" %}
            </figure>

            {% if gallery %}
              {% for galleryImage in gallery %}
                {% set galleryIndex = loop.index + 1 %}
                {% set galleryAlt = title ~ " — изображение " ~ galleryIndex %}
                <figure
                  class="work-detail__image-wrapper work-carousel__slide"
                  data-carousel-slide
                  role="group"
                  aria-roledescription="слайд"
                  aria-label="{{ galleryIndex }} из {{ imageCount }}"
                  aria-hidden="true"
                >
                  {% detailImage galleryImage, galleryAlt, "work-detail__image work-detail__image--additional", "lazy", "" %}
                </figure>
              {% endfor %}
            {% endif %}
          </div>
        </div>

        {% if imageCount > 1 %}
          <div class="work-carousel__controls">
            <button class="work-carousel__button" type="button" data-carousel-previous aria-label="Предыдущее изображение">
              <span aria-hidden="true">←</span>
            </button>
            <p class="work-carousel__counter" aria-live="polite">
              <span class="visually-hidden">Изображение </span>
              <span data-carousel-current>1</span>
              <span aria-hidden="true"> / </span>
              <span class="visually-hidden"> из </span>
              <span>{{ imageCount }}</span>
            </p>
            <button class="work-carousel__button" type="button" data-carousel-next aria-label="Следующее изображение">
              <span aria-hidden="true">→</span>
            </button>
          </div>
        {% endif %}
      </section>
    {% endif %}

    {% if year or dimensions or materials %}
      <div class="work-detail__meta">
        {% if year %}
          <p class="work-detail__meta-item">{{ year }}</p>
        {% endif %}
        {% if dimensions %}
          <p class="work-detail__meta-item">{{ dimensions }}</p>
        {% endif %}
        {% if materials %}
          <p class="work-detail__meta-item">{{ materials }}</p>
        {% endif %}
      </div>
    {% endif %}

    {% if description %}
      <p class="work-detail__description">{{ description }}</p>
    {% endif %}

    {% if bodyContent %}
      <div class="work-detail__content">
        {{ content | safe }}
      </div>
    {% endif %}

    <footer class="work-detail__footer">
      <nav class="work-detail__pagination" aria-label="Навигация по работам">
        {% if previousWork %}
          <a href="{{ previousWork.url }}" class="work-detail__pagination-link work-detail__pagination-link--previous">
            <span class="work-detail__pagination-direction">← Предыдущая</span>
            <span class="work-detail__pagination-title">{{ previousWork.data.title }}</span>
          </a>
        {% else %}
          <span class="work-detail__pagination-placeholder" aria-hidden="true"></span>
        {% endif %}

        <a href="{{ backHref }}" class="work-detail__back">Все: {{ backLabel }}</a>

        {% if nextWork %}
          <a href="{{ nextWork.url }}" class="work-detail__pagination-link work-detail__pagination-link--next">
            <span class="work-detail__pagination-direction">Следующая →</span>
            <span class="work-detail__pagination-title">{{ nextWork.data.title }}</span>
          </a>
        {% else %}
          <span class="work-detail__pagination-placeholder" aria-hidden="true"></span>
        {% endif %}
      </nav>
    </footer>
  </article>
</div>
